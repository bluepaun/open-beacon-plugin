{
  "name": "@bluepaun/open-beacon-plugin",
  "version": "0.1.1",
  "description": "OpenCode migration of Beacon semantic code search",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SPEC.md",
    "templates"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm",
    "test": "bun test",
    "test:coverage": "bun run scripts/check-coverage-threshold.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "beacon",
    "semantic-search",
    "code-search"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluepaun/open-beacon-plugin.git"
  },
  "homepage": "https://github.com/bluepaun/open-beacon-plugin#readme",
  "bugs": {
    "url": "https://github.com/bluepaun/open-beacon-plugin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "picomatch": "^4.0.3",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.24",
    "@types/picomatch": "^4.0.2",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.2"
  }
}
